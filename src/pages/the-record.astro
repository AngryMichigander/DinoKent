---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const records = await getCollection("records");
records.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryLabels: Record<string, string> = {
  legal: "Legal",
  credentials: "Credentials",
  conduct: "Conduct",
};

const categoryColors: Record<string, string> = {
  legal: "bg-red-500/10 text-red-400 border-red-500/20",
  credentials: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  conduct: "bg-purple-500/10 text-purple-400 border-purple-500/20",
};
---

<BaseLayout title="The Record" description="Kent Hovind's criminal record, fake credentials, and documented misconduct — sourced from court documents and public records.">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-3">The Record</h1>
    <p class="text-muted mb-10 leading-relaxed">
      Documented facts about Kent Hovind's legal history, credentials, and conduct.
      Every entry cites primary sources: court documents, institutional records, or
      contemporaneous reporting.
    </p>

    <div class="space-y-8">
      {
        records.map(async (record) => {
          const { Content } = await record.render();
          return (
            <article class="rounded-xl border border-border bg-surface p-6">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span
                  class:list={[
                    "text-xs font-medium px-2.5 py-1 rounded-full border",
                    categoryColors[record.data.category],
                  ]}
                >
                  {categoryLabels[record.data.category]}
                </span>
                <time class="text-xs text-faint">
                  {record.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
              <h2 class="text-xl font-bold text-text mb-2">{record.data.title}</h2>
              <p class="text-muted text-sm mb-4">{record.data.summary}</p>
              <div class="prose prose-sm max-w-none">
                <Content />
              </div>
              {record.data.sources.length > 0 && (
                <div class="mt-4 pt-4 border-t border-border">
                  <p class="text-xs font-medium text-faint mb-2">Sources</p>
                  <ul class="space-y-1">
                    {record.data.sources.map((src) => (
                      <li>
                        <a
                          href={src.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-xs text-accent hover:underline"
                        >
                          {src.label} ↗
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </article>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
