---
import BaseLayout from "../layouts/BaseLayout.astro";

const pillars = [
  {
    title: "The Record",
    href: "/the-record",
    icon: "📋",
    description:
      "Tax fraud conviction, fake PhD, and documented harassment. Court records, not opinions.",
  },
  {
    title: "The Arguments",
    href: "/the-arguments",
    icon: "🔬",
    description:
      "Point-by-point rebuttals of creationist talking points with peer-reviewed sources.",
  },
  {
    title: "In His Own Words",
    href: "/in-his-own-words",
    icon: "🎙️",
    description:
      "Direct quotes and video timestamps paired with what the science actually says.",
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="text-center py-12 sm:py-20">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-text mb-6">
      The Facts About<br />
      <span class="text-accent">Kent Hovind</span>
    </h1>
    <p class="text-lg sm:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
      A sourced, fact-based reference for journalists, educators, and anyone
      encountering Kent "Dr. Dino" Hovind's claims. Every assertion on this site
      links to court documents, peer-reviewed research, or primary sources.
    </p>
  </section>

  <!-- Pillars -->
  <section class="grid md:grid-cols-3 gap-6 mt-4">
    {
      pillars.map((pillar) => (
        <a
          href={pillar.href}
          class="group block rounded-xl border border-border bg-surface p-6 hover:border-accent/50 hover:bg-surface-alt transition-all duration-200"
        >
          <span class="text-3xl mb-4 block">{pillar.icon}</span>
          <h2 class="text-xl font-bold text-text mb-2 group-hover:text-accent transition-colors">
            {pillar.title}
          </h2>
          <p class="text-muted text-sm leading-relaxed">
            {pillar.description}
          </p>
        </a>
      ))
    }
  </section>

  <!-- Brief context -->
  <section class="mt-16 max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-text mb-4">Who is Kent Hovind?</h2>
    <div class="prose prose-sm max-w-none space-y-4">
      <p>
        Kent Hovind (b. 1953) is an American young-earth creationist and
        tax protester who runs "Dinosaur Adventure Land" — originally in Pensacola,
        Florida (seized by the government), now rebuilt in Repton, Alabama. He styles
        himself "Dr. Dino" based on a mail-order PhD from the unaccredited Patriot Bible University.
      </p>
      <p>
        In 2006, Hovind and his wife were convicted on 58 federal counts
        including tax evasion, structuring financial transactions to evade
        reporting requirements, and other offenses. He served approximately
        eight years in federal prison before his release in 2015.
      </p>
      <p>
        Despite his criminal record and lack of legitimate academic credentials,
        Hovind continues to produce content promoting young-earth creationism
        and attacking evolutionary biology. This site exists to provide accurate,
        well-sourced responses to his claims.
      </p>
    </div>
  </section>

  <!-- Credibility note -->
  <section
    class="mt-16 rounded-xl border border-border bg-surface-alt p-6 text-center"
  >
    <p class="text-faint text-sm">
      <strong class="text-muted">Editorial standards:</strong> This site
      cites court documents, peer-reviewed journals, and established scientific
      institutions. We correct mistakes — see the footer to report an error.
    </p>
  </section>
</BaseLayout>
