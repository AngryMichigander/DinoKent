---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const records = await getCollection("records");

// Sort chronologically (oldest first)
const events = records
  .map((record) => ({
    date: record.data.date,
    title: record.data.title,
    summary: record.data.summary,
    category: record.data.category,
    slug: record.slug,
  }))
  .sort((a, b) => a.date.getTime() - b.date.getTime());

const categoryLabels: Record<string, string> = {
  legal: "Legal",
  credentials: "Credentials",
  conduct: "Conduct",
};

const categoryColors: Record<string, string> = {
  legal: "bg-red-500/10 text-red-400 border-red-500/20",
  credentials: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  conduct: "bg-purple-500/10 text-purple-400 border-purple-500/20",
};

const categoryDots: Record<string, string> = {
  legal: "bg-red-500",
  credentials: "bg-amber-500",
  conduct: "bg-purple-500",
};
---

<BaseLayout title="Timeline" description="A chronological timeline of Kent Hovind's criminal record, legal battles, fake credentials, and documented misconduct.">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-3">Timeline</h1>
    <p class="text-muted mb-10 leading-relaxed">
      A chronological account of Kent Hovind's documented history — from his
      unaccredited degree to his most recent conviction. Every entry links to a
      fully sourced record.
    </p>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-border"></div>

      <div class="space-y-10">
        {
          events.map((event) => (
            <div class="relative pl-12">
              {/* Dot on the timeline */}
              <div
                class:list={[
                  "absolute left-2.5 top-1.5 w-3 h-3 rounded-full ring-4 ring-bg",
                  categoryDots[event.category],
                ]}
              />

              {/* Year label */}
              <time class="text-xs font-semibold text-accent tracking-wider uppercase">
                {event.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                })}
              </time>

              <h2 class="text-lg font-bold text-text mt-1 mb-1">
                <a
                  href={`/records/${event.slug}`}
                  class="hover:text-accent transition-colors"
                >
                  {event.title}
                </a>
              </h2>

              <div class="flex items-center gap-2 mb-2">
                <span
                  class:list={[
                    "text-xs font-medium px-2 py-0.5 rounded-full border",
                    categoryColors[event.category],
                  ]}
                >
                  {categoryLabels[event.category]}
                </span>
              </div>

              <p class="text-muted text-sm leading-relaxed">{event.summary}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
