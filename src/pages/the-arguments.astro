---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const args = await getCollection("arguments");
args.sort((a, b) => a.data.title.localeCompare(b.data.title));

const verdictLabels: Record<string, string> = {
  false: "False",
  misleading: "Misleading",
  unsupported: "Unsupported",
  outdated: "Outdated",
};

const verdictColors: Record<string, string> = {
  false: "bg-red-500/10 text-red-400 border-red-500/20",
  misleading: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  unsupported: "bg-orange-500/10 text-orange-400 border-orange-500/20",
  outdated: "bg-gray-500/10 text-gray-400 border-gray-500/20",
};

const categoryLabels: Record<string, string> = {
  evolution: "Evolution",
  geology: "Geology",
  physics: "Physics",
  biology: "Biology",
  cosmology: "Cosmology",
  general: "General",
};
---

<BaseLayout title="The Arguments" description="Point-by-point rebuttals of Kent Hovind's creationist claims, backed by peer-reviewed science.">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-3">The Arguments</h1>
    <p class="text-muted mb-10 leading-relaxed">
      Hovind recycles a set of creationist talking points that have been thoroughly
      addressed by the scientific community. Each rebuttal below includes the claim,
      the scientific response, and links to peer-reviewed sources.
    </p>

    <div class="space-y-8">
      {
        args.map(async (arg) => {
          const { Content } = await arg.render();
          return (
            <article class="rounded-xl border border-border bg-surface p-6">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span
                  class:list={[
                    "text-xs font-medium px-2.5 py-1 rounded-full border",
                    verdictColors[arg.data.verdict],
                  ]}
                >
                  {verdictLabels[arg.data.verdict]}
                </span>
                <span class="text-xs text-faint px-2 py-0.5 rounded bg-surface-alt">
                  {categoryLabels[arg.data.category]}
                </span>
              </div>
              <h2 class="text-xl font-bold text-text mb-2">{arg.data.title}</h2>
              <blockquote class="border-l-2 border-border pl-4 text-muted text-sm italic mb-4">
                "{arg.data.claim}"
              </blockquote>
              <div class="prose prose-sm max-w-none">
                <Content />
              </div>
              {arg.data.sources.length > 0 && (
                <div class="mt-4 pt-4 border-t border-border">
                  <p class="text-xs font-medium text-faint mb-2">Sources</p>
                  <ul class="space-y-1">
                    {arg.data.sources.map((src) => (
                      <li>
                        <a
                          href={src.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-xs text-accent hover:underline"
                        >
                          {src.label} ↗
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </article>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
