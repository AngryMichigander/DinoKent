---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const quotes = await getCollection("quotes");
quotes.sort((a, b) => {
  if (a.data.date && b.data.date) return b.data.date.getTime() - a.data.date.getTime();
  return 0;
});
---

<BaseLayout title="In His Own Words" description="Direct quotes from Kent Hovind paired with scientific rebuttals and sources.">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-3">In His Own Words</h1>
    <p class="text-muted mb-10 leading-relaxed">
      Kent Hovind's own statements, presented alongside what the evidence actually shows.
      Video links and timestamps included where available.
    </p>

    <div class="space-y-8">
      {
        quotes.map(async (q) => {
          const { Content } = await q.render();
          return (
            <article class="rounded-xl border border-border bg-surface p-6">
              <blockquote class="text-lg font-medium text-text leading-relaxed mb-3 border-l-4 border-accent/50 pl-4">
                "{q.data.quote}"
              </blockquote>
              <div class="flex flex-wrap items-center gap-3 mb-4 text-xs text-faint">
                <span>{q.data.source}</span>
                {q.data.date && (
                  <span>
                    {q.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                    })}
                  </span>
                )}
                {q.data.videoUrl && (
                  <a
                    href={`${q.data.videoUrl}${q.data.timestamp ? `&t=${q.data.timestamp}` : ""}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent hover:underline"
                  >
                    Watch clip ↗
                  </a>
                )}
              </div>

              <div class="rounded-lg bg-surface-alt border border-border p-4 mb-4">
                <p class="text-xs font-semibold text-accent mb-2 uppercase tracking-wide">
                  What the evidence says
                </p>
                <p class="text-sm text-muted">{q.data.rebuttalSummary}</p>
              </div>

              <div class="prose prose-sm max-w-none">
                <Content />
              </div>

              {q.data.sources.length > 0 && (
                <div class="mt-4 pt-4 border-t border-border">
                  <p class="text-xs font-medium text-faint mb-2">Sources</p>
                  <ul class="space-y-1">
                    {q.data.sources.map((src) => (
                      <li>
                        <a
                          href={src.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-xs text-accent hover:underline"
                        >
                          {src.label} ↗
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </article>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
