---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const records = await getCollection("records");
  return records.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryLabels: Record<string, string> = {
  legal: "Legal",
  credentials: "Credentials",
  conduct: "Conduct",
};

const categoryColors: Record<string, string> = {
  legal: "bg-red-500/10 text-red-400 border-red-500/20",
  credentials: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  conduct: "bg-purple-500/10 text-purple-400 border-purple-500/20",
};

const description = `${entry.data.summary} Sourced from court documents and public records.`;
---

<BaseLayout title={entry.data.title} description={description} ogType="article">
  <div class="max-w-3xl mx-auto">
    <nav class="mb-8">
      <a href="/the-record" class="text-sm text-accent hover:underline">&larr; Back to The Record</a>
    </nav>

    <article>
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span
          class:list={[
            "text-xs font-medium px-2.5 py-1 rounded-full border",
            categoryColors[entry.data.category],
          ]}
        >
          {categoryLabels[entry.data.category]}
        </span>
        <time class="text-xs text-faint">
          {entry.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-4">{entry.data.title}</h1>

      <p class="text-muted mb-8">{entry.data.summary}</p>

      <div class="prose prose-sm max-w-none">
        <Content />
      </div>

      {entry.data.sources.length > 0 && (
        <div class="mt-8 pt-6 border-t border-border">
          <h2 class="text-sm font-semibold text-text mb-3">Sources</h2>
          <ul class="space-y-2">
            {entry.data.sources.map((src) => (
              <li>
                <a
                  href={src.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-accent hover:underline"
                >
                  {src.label} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </article>
  </div>
</BaseLayout>
